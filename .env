# React Front-end Environment Example

REACT_APP_API_BASE_URL=http://127.0.0.1:8000/api
REACT_APP_APP_NAME=RS App

# Authentication
REACT_APP_API_LOGIN_URI=/login
REACT_APP_API_REGISTER_URI=/register
REACT_APP_API_ME_URI=/me
REACT_APP_API_PROFILE_URI=/profile
REACT_APP_API_LOGOUT_URI=/logout

# Admin dashboard
REACT_APP_API_DASHBOARD_URI=/dashboard
REACT_APP_API_DASHBOARD_STATISTIK_PASIEN_URI=/dashboard/statistik-pasien
REACT_APP_API_DASHBOARD_STATISTIK_DOKTER_URI=/dashboard/statistik-dokter
REACT_APP_API_DASHBOARD_STATISTIK_PENDAFTARAN_URI=/dashboard/statistik-pendaftaran
REACT_APP_API_DASHBOARD_PENDAFTARAN_TERBARU_URI=/dashboard/pendaftaran-terbaru
REACT_APP_API_DASHBOARD_AKTIVITAS_HARI_INI_URI=/dashboard/aktivitas-hari-ini

# Dokter
REACT_APP_API_DOKTER_URI=/dokter
REACT_APP_API_DOKTER_SPESIALISASI_URI=/dokter/spesialisasi

# Jadwal
REACT_APP_API_JADWAL_URI=/jadwal
REACT_APP_API_JADWAL_BY_DOKTER_URI=/jadwal/dokter

# Pasien
REACT_APP_API_PASIEN_URI=/pasien

# Pendaftaran
REACT_APP_API_PENDAFTARAN_VERIFY_URI=/pendaftaran
REACT_APP_API_PENDAFTARAN_BY_PASIEN_URI=/pendaftaran/pasien
REACT_APP_API_PENDAFTARAN_BY_DOKTER_URI=/pendaftaran/dokter

# Rekam Medis
REACT_APP_API_REKAM_MEDIS_URI=/rekam-medis
REACT_APP_API_REKAM_MEDIS_BY_PASIEN_URI=/rekam-medis/pasien
REACT_APP_API_REKAM_MEDIS_BY_DOKTER_URI=/rekam-medis/dokter

# Pasien-specific
REACT_APP_API_RIWAYAT_URI=/riwayat
REACT_APP_API_ANTRIAN_URI=/antrian
REACT_APP_API_PASIEN_SAYA_URI=/pasien-saya

# Laporan
REACT_APP_API_LAPORAN_URI=/laporan
REACT_APP_API_LAPORAN_PASIEN_URI=/laporan/pasien
REACT_APP_API_LAPORAN_REKAM_MEDIS_URI=/laporan/rekam-medis
REACT_APP_API_LAPORAN_DOKTER_URI=/laporan/dokter
REACT_APP_API_LAPORAN_PENDAFTARAN_URI=/laporan/pendaftaran
REACT_APP_API_LAPORAN_EXPORT_PDF_URI=/laporan/export-pdf
REACT_APP_API_LAPORAN_EXPORT_EXCEL_URI=/laporan/export-excel

